rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    match /rooms/{roomId} {
      allow read, write: if isAuthenticated();
    }
    
    match /questions/{questionId} {
      allow read, write: if isAuthenticated();
    }
  }
}
