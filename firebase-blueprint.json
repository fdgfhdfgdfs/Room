{
  "entities": {
    "Room": {
      "title": "Room",
      "type": "object",
      "properties": {
        "hostId": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "asking", "answering", "judging"] },
        "playerOrder": { "type": "array", "items": { "type": "string" } },
        "players": { "type": "object" },
        "currentAskerIndex": { "type": "number" },
        "currentQuestion": { "type": "string" },
        "answers": { "type": "object" },
        "questionStartedAt": { "type": "number" }
      }
    }
  },
  "firestore": {
    "rooms/{roomId}": {
      "schema": { "$ref": "#/entities/Room" }
    }
  }
}
